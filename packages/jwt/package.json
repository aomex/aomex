{
  "name": "@aomex/jwt",
  "version": "0.0.3",
  "description": "JSON Web Token",
  "keywords": [
    "json-web-token"
  ],
  "repository": "git@github.com:aomex/aomex.git",
  "homepage": "https://aomex.js.org",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "prepublishOnly": "tsup"
  },
  "types": "src/index.ts",
  "exports": "./src/index.ts",
  "files": [
    "dist",
    "LICENSE",
    "package.json",
    "README.md",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "types": "dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./package.json": "./package.json"
    },
    "access": "public"
  },
  "peerDependencies": {
    "@aomex/core": "^0.0.5",
    "@aomex/web": "^0.0.6"
  },
  "dependencies": {
    "@aomex/helper": "workspace:0.0.3",
    "@types/jsonwebtoken": "^9.0.1",
    "cookie": "^0.5.0",
    "jsonwebtoken": "^9.0.0"
  },
  "devDependencies": {
    "@aomex/core": "workspace:^0.0.5",
    "@aomex/web": "workspace:^0.0.6",
    "@types/cookie": "^0.5.1"
  }
}
