// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`output cron:* help information 1`] = `
"aomex [command] [options] [--help|-h]

Commands:
  aomex cron:start   Star cron
  aomex cron:export  Create cron-compatibly list

Options:
  -v, --version  Show aomex version number                             [boolean]
  -h, --help     Show help                                             [boolean]"
`;

exports[`output cron:* help information 2`] = `
"aomex cron:start [options]

Options:
  -h, --help  Show help for command "cron:start""
`;

exports[`output cron:* help information 3`] = `
"aomex cron:export [options]

Options:
  -o, --output  Export to specific file                                 [string]
  -h, --help    Show help for command "cron:export""
`;
