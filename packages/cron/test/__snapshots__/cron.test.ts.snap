// Vitest Snapshot v1

exports[`output schedule:* help information 1`] = `
"aomex [command] [options] [--help|-h]

Commands:
  aomex schedule:run     Star cron
  aomex schedule:export  Create cron-compatibly list

Options:
  -v, --version  Show aomex version number                             [boolean]
  -h, --help     Show help                                             [boolean]"
`;

exports[`output schedule:* help information 2`] = `
"aomex schedule:run [options]
Schedule list:


Options:
  -h, --help  Show help for command "schedule:run""
`;

exports[`output schedule:* help information 3`] = `
"aomex schedule:export [options]

Options:
  -o, --output  Export to specific file                                 [string]
  -h, --help    Show help for command "schedule:export""
`;
