{
  "name": "@aomex/logger",
  "version": "0.0.6",
  "description": "web request log",
  "keywords": [
    "api-request-logger"
  ],
  "repository": "git@github.com:aomex/aomex.git",
  "homepage": "https://aomex.js.org",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "prepublishOnly": "tsup"
  },
  "types": "src/index.ts",
  "exports": "./src/index.ts",
  "files": [
    "dist",
    "LICENSE",
    "package.json",
    "README.md",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "types": "dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./package.json": "./package.json"
    },
    "access": "public"
  },
  "peerDependencies": {
    "@aomex/core": "^0.0.9",
    "@aomex/web": "^0.0.11"
  },
  "dependencies": {
    "@aomex/utility": "workspace:0.0.5",
    "pretty-time": "^1.1.0"
  },
  "devDependencies": {
    "@aomex/core": "workspace:^0.0.9",
    "@aomex/web": "workspace:^0.0.11",
    "@types/pretty-time": "^1.1.2",
    "strip-ansi": "^7.0.1"
  }
}
